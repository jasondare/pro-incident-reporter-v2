# =============================================================================
# INCIDENT REPORTER API - ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.
#
# For Firebase deployment, set these in Firebase App Hosting secrets or
# environment variables via the Firebase console.
# =============================================================================

# =============================================================================
# API AUTHENTICATION (required)
# =============================================================================
# Generate a secure token: openssl rand -hex 24
#
# INCIDENT_API_SECRET: Server-side secret for validating bearer tokens.
#                      Keep this secret. Never expose in client code.
#
# NEXT_PUBLIC_INCIDENT_API_TOKEN: Client-side token (same value as above).
#                                 This is intentionally public - it's a
#                                 lightweight anti-abuse measure, not true auth.
#
# IMPORTANT: Both values MUST match for authentication to work.
INCIDENT_API_SECRET=
NEXT_PUBLIC_INCIDENT_API_TOKEN=

# =============================================================================
# FIREBASE (server only)
# =============================================================================
# Firebase Admin SDK credentials for Firestore access.
#
# Use EITHER:
#   BE_FIREBASE_SERVICE_ACCOUNT_KEY  - Inline JSON (escaped, single line)
#
# Generate at: Firebase Console > Project Settings > Service accounts
#
# For Firebase App Hosting: Use Secret Manager for BE_FIREBASE_SERVICE_ACCOUNT_KEY.
BE_FIREBASE_SERVICE_ACCOUNT_KEY=
# FIREBASE_SERVICE_ACCOUNT_PATH=/path/to/service-account.json

# Firestore collection app ID (for multi-tenant setups)
FIREBASE_ARTIFACT_APP_ID=everyday-mandarin

# =============================================================================
# GEMINI AI (server only)
# =============================================================================
# Google AI Studio API key for Gemini model access.
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Gemini model to use (default: gemini-2.0-flash)
GEMINI_MODEL=gemini-2.5-flash

# =============================================================================
# PRODUCTION DEPLOYMENT CHECKLIST
# =============================================================================
# Before deploying to production, ensure:
#
# 1. INCIDENT_API_SECRET is a strong, unique value (openssl rand -hex 24)
# 2. BE_FIREBASE_SERVICE_ACCOUNT_KEY is set via Firebase Secrets Manager
# 3. GEMINI_API_KEY is set and has appropriate quota
#
# Firebase App Hosting deployment:
#   firebase apphosting:secrets:set INCIDENT_API_SECRET
#   firebase apphosting:secrets:set BE_FIREBASE_SERVICE_ACCOUNT_KEY
#   firebase apphosting:secrets:set GEMINI_API_KEY
# =============================================================================
